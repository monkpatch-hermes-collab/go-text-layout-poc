 	return objabi.LookupPkgSpecial(pkg).Runtime
 }
 
+func movableTextStart(ldr *loader.Loader, textp []loader.Sym) int {
+	i := 0
+	// don't move the buildid symbol
+	if len(textp) > 0 && ldr.SymName(textp[0]) == "go:buildid" {
+		i++
+	}
+	// Skip over C symbols, as functions in a (C object) section must stay together.
+	// TODO: maybe we can move a section as a whole.
+	// Note: we load C symbols before Go symbols, so we can scan from the start.
+	for i < len(textp) && (ldr.SubSym(textp[i]) != 0 || ldr.AttrSubSymbol(textp[i])) {
+		i++
+	}
+	return i
+}
+
+func applyTextOrder(ctxt *Link, orderFile string) {
+	if orderFile == "" {
+		return
+	}
+	data, err := os.ReadFile(orderFile)
+	if err != nil {
+		Exitf("read text order %s: %v", orderFile, err)
+	}
+	order := make(map[string]int)
+	for _, line := range strings.Split(string(data), "\n") {
+		line = strings.TrimSpace(line)
+		if line == "" || strings.HasPrefix(line, "#") {
+			continue
+		}
+		if _, exists := order[line]; !exists {
+			order[line] = len(order)
+		}
+	}
+	if len(order) == 0 {
+		return
+	}
+
+	ldr := ctxt.loader
+	textp := ctxt.Textp[movableTextStart(ldr, ctxt.Textp):]
+	sort.SliceStable(textp, func(i, j int) bool {
+		ri, iok := order[ldr.SymName(textp[i])]
+		rj, jok := order[ldr.SymName(textp[j])]
+		if iok != jok {
+			return iok
+		}
+		if iok {
+			return ri < rj
+		}
+		return false
+	})
+}
